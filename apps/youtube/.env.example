# Copy this file to `.env.local` (git-ignored) and fill in your key.
#   cp .env.example .env.local

# OpenAI API key. When set, /api/generate uses OpenAI; when empty/absent it falls
# back to the deterministic mock generator. Never commit the real value.
OPENAI_API_KEY=

# Optional: override the model. Default is gpt-5.4-mini (see @dotui/llm's openaiGenerator).
# For higher quality use the full-size sibling:
# OPENAI_MODEL=gpt-5.4
